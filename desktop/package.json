{
    "name": "stock-intervention-desktop",
    "version": "1.0.0",
    "description": "Application desktop de gestion de stock et d'interventions",
    "main": "electron.js",
    "scripts": {
        "start": "electron . --no-sandbox",
        "dev": "concurrently \"npm run dev:react\" \"wait-on http://localhost:3000 && electron . --no-sandbox\"",
        "dev:react": "vite",
        "build:react": "vite build",
        "build": "npm run build:react && electron-builder",
        "build:linux": "npm run build:react && electron-builder --linux",
        "build:win": "npm run build:react && electron-builder --win"
    },
    "build": {
        "appId": "com.stockintervention.app",
        "productName": "Stock & Interventions",
        "directories": {
            "output": "dist"
        },
        "files": [
            "electron.js",
            "dist/**/*",
            "package.json"
        ],
        "linux": {
            "target": [
                "deb"
            ],
            "category": "Utility",
            "icon": "assets/icon.png"
        },
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "assets/icon.ico"
        }
    },
    "dependencies": {
        "@types/react-big-calendar": "^1.16.3",
        "electron-store": "^8.1.0",
        "jsbarcode": "^3.12.1",
        "jspdf": "^3.0.4",
        "jspdf-autotable": "^5.0.2",
        "moment": "^2.30.1",
        "react-big-calendar": "^1.19.4"
    },
    "devDependencies": {
        "@types/react": "^18.2.45",
        "@types/react-dom": "^18.2.18",
        "@vitejs/plugin-react": "^4.2.1",
        "axios": "^1.6.2",
        "concurrently": "^8.2.2",
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-router-dom": "^6.20.1",
        "typescript": "^5.3.3",
        "vite": "^5.0.8",
        "wait-on": "^7.2.0"
    }
}
